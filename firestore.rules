rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidDevice(data) {
      return data.keys().hasAll(['angle', 'lastUpdated']) 
             && data.keys().size() <= 5
             && data.angle is number 
             && data.angle >= -180 && data.angle <= 180
             && data.lastUpdated == request.time;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['doctorName', 'specialty', 'date', 'time', 'status', 'fee'])
             && data.doctorName is string && data.doctorName.size() <= 100
             && data.status in ['confirmed', 'pending', 'cancelled'];
    }

    function isValidThresholds(data) {
      return data.keys().hasAll(['good', 'warn', 'bad'])
             && data.good is number && data.warn is number && data.bad is number
             && data.good > data.warn && data.warn > data.bad;
    }

    match /devices/{deviceId} {
      allow read, write: if true;
      match /{allPaths=**} {
        allow read, write: if true;
      }
    }

    match /posture/{id=**} { allow read, write: if true; }
    match /telemetry/{id=**} { allow read, write: if true; }
    match /readings/{id=**} { allow read, write: if true; }
    match /data/{id=**} { allow read, write: if true; }
    match /history/{id=**} { allow read, write: if true; }
    match /sensor_data/{id=**} { allow read, write: if true; }
    match /angles/{id=**} { allow read, write: if true; }
    match /logs/{id=**} { allow read, write: if true; }
    match /sensor/{id=**} { allow read, write: if true; }
    match /postures/{id=**} { allow read, write: if true; }

    match /users/{userId} {
      match /appointments/{appointmentId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAppointment(incoming());
        allow update: if isOwner(userId) && isValidAppointment(incoming()) 
                      && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'date', 'time']);
        allow delete: if isOwner(userId);
      }

      match /settings/thresholds {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidThresholds(incoming());
      }
    }
  }
}
